-- Secret Chinese-substitution chat (lightweight 2026)

local Chinese = {
    a = "的", b = "一", c = "是", d = "不", e = "了", f = "人", g = "我",
    h = "在", i = "有", j = "他", k = "这", l = "为", m = "之", n = "大",
    o = "来", p = "以", q = "个", r = "中", s = "上", t = "们", u = "到",
    v = "说", w = "国", x = "和", y = "地", z = "也"
}

local PREFIX = "[秘]"

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local TextChatService = game:GetService("TextChatService")

local reverseMap = {}
for eng, chi in pairs(Chinese) do
    reverseMap[chi] = eng
end

local function decode(str)
    if not str or type(str) ~= "string" then return nil end
    if str:sub(1, #PREFIX) ~= PREFIX then return nil end
    str = str:sub(#PREFIX + 1)
    local result = ""
    for char in str:gmatch("[%z\1-\127\194-\244][\128-\191]*") do
        result = result .. (reverseMap[char] or "?")
    end
    return result
end

local function encode(str)
    str = str:lower()
    local result = ""
    for char in str:gmatch(".") do
        result = result .. (Chinese[char] or char)
    end
    return PREFIX .. result
end

-- ────────────────────────────────────────
-- SEND
-- ────────────────────────────────────────
local function sendChat(msg)
    local encoded = encode(msg)
    print("Sending encoded:", encoded) -- debug

    if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
        -- Try ALL text channels, not just RBXGeneral
        local textChannels = TextChatService:FindFirstChild("TextChannels")
        if textChannels then
            for _, ch in ipairs(textChannels:GetChildren()) do
                if ch:IsA("TextChannel") then
                    pcall(function()
                        ch:SendAsync(encoded)
                        print("Sent to channel:", ch.Name)
                    end)
                end
            end
        else
            warn("No TextChannels folder found")
        end
    else
        local replicated = game:GetService("ReplicatedStorage")
        local legacyEvent = replicated:FindFirstChild("DefaultChatSystemChatEvents", true)
        if legacyEvent then
            local sayMsg = legacyEvent:FindFirstChild("SayMessageRequest")
            if sayMsg then
                sayMsg:FireServer(encoded, "All")
                print("Sent via legacy")
            end
        end
    end
end

