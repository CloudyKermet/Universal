box.ClearTextOnFocus = false

local function onSubmit()
    local text = box.Text
    if text == "" then return end
    sendChat(text)
    box.Text = ""
end

box.FocusLost:Connect(function(enterPressed)
    if enterPressed then onSubmit() end
end)

-- ────────────────────────────────────────
-- INTERCEPT — decode + color yellow
-- ────────────────────────────────────────
if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
    local original = TextChatService.OnIncomingMessage

    TextChatService.OnIncomingMessage = function(message)
        local text = message.Text
        
        -- Debug: print every message that comes through
        if text then
            local hasPrefix = text:sub(1, #PREFIX) == PREFIX
            -- Only print debug for prefixed messages to avoid spam
            if hasPrefix then
                print("OnIncomingMessage received:", text)
            end
        end

        if text and type(text) == "string" and text:sub(1, #PREFIX) == PREFIX then
            local decoded = decode(text)
            if decoded then
                print("Decoded to:", decoded)
                local props = Instance.new("TextChatMessageProperties")
                props.Text = "<font color='rgb(255,215,0)'>" .. decoded .. "</font>"
                return props
            end
        end

        if original then
            return original(message)
        end
        return nil
    end

    print("OnIncomingMessage hook set up successfully")
else
    warn("Chat version is not TextChatService, it's:", TextChatService.ChatVersion)
end

print("Secret Chat loaded. Prefix: " .. PREFIX)
